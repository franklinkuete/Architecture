{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MariaDbSetting": {
    "ConnectionString": "Server=localhost;Port=3307;Database=${MARIADB_DATABASE};Uid=${MARIADB_USER};Pwd=${MARIADB_PASSWORD}",
    "DatabaseName": "${MARIADB_DATABASE}"
  },

  "KafkaSettings": {
    "BootstrapServers": "localhost:29092",
    "GroupId": "product-consumer-group",
    "Debug": "all",
    "MessageTimeoutMs": 10000,
    "KafkaTransaction": {
      "Name": "commande-created-stock-update",
      "ProducerTopic": "commande-created-topic",
      "ConsumerTopic": "stock-failed-topic"
    },
    "MassTransitTransaction": {
      "Name": "commande-cancel-stock-update",
      "ProducerTopic": "commande-cancel",
      "ConsumerTopic": ""
    }

  }
}
